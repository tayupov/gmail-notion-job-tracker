{
  "name": "gmail-notion-job-tracker",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "Reads recent Gmail twice a day, detects job-application status changes with Claude, and syncs them to a Notion table.",
  "license": "MIT",
  "author": "Roman Tayupov",
  "keywords": [
    "job-tracker",
    "job-applications",
    "gmail",
    "notion",
    "claude",
    "anthropic",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tayupov/gmail-notion-job-tracker.git"
  },
  "homepage": "https://github.com/tayupov/gmail-notion-job-tracker#readme",
  "bugs": {
    "url": "https://github.com/tayupov/gmail-notion-job-tracker/issues"
  },
  "scripts": {
    "track": "tsx src/main.ts",
    "get-token": "tsx scripts/get-refresh-token.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@notionhq/client": "^2.3.0",
    "dotenv": "^17.0.0",
    "googleapis": "^165.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
