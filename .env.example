# --- Anthropic ---
# API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Google / Gmail (read-only) ---
# From a Google Cloud OAuth "Desktop app" client (Gmail API enabled).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Mint this once locally:  npm run get-token
GOOGLE_REFRESH_TOKEN=

# --- Notion ---
# Internal integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=
# The tracker database id (the 32-char id in the database URL).
NOTION_DATABASE_ID=

# --- Optional ---
# When "true", logs the actions Claude proposes but writes nothing to Notion.
DRY_RUN=false
# How far back to read email. Gmail query syntax. Default: newer_than:1d in:inbox
GMAIL_QUERY=newer_than:1d in:inbox
